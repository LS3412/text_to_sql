# PostgreSQL Configuration (Updated Port)
DB_HOST=localhost
DB_PORT=5435
DB_USER=a2a_user
DB_PASSWORD=secure_password_change_me
DB_NAME=a2a_db
# Read-only role used by the SQL Skill to run generated SELECTs (§7.2) and by the
# startup SQLDatabase reflection (sync psycopg2 engine).
DB_READONLY_USER=a2a_readonly
DB_READONLY_PASSWORD=readonly_secure_password_change_me

# Redis Cache Configuration (Updated Port)
REDIS_HOST=localhost
REDIS_PORT=6385
REDIS_PASSWORD=redis_secure_password_change_me
REDIS_DB=0

# LLM Configuration
# LLM_PROVIDER selects how Settings.llm is built: ollama | anthropic | openai.
# Default ollama keeps everything local/offline. For anthropic/openai also set
# LLM_API_KEY and an appropriate LLM_MODEL, and pip install the matching package.
LLM_PROVIDER=ollama
LLM_MODEL=qwen2:7b
LLM_BASE_URL=http://localhost:11434
LLM_TIMEOUT=120
# LLM_API_KEY=

# Application Configuration
# Number of recent conversation turns loaded per session for context (§3.1)
APP_MEMORY_TURNS=5
# Public base URL advertised in the A2A Agent Card and used as the JSON-RPC endpoint
APP_A2A_AGENT_URL=http://localhost:8000

# ClickHouse Configuration
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8125
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=secure_password_change_me

# Evaluation (DeepEval) — see evals/README.md
# The judge LLM defaults to the agent's LLM_* settings (offline by default). For
# meaningful LLM-judged scores, point it at a stronger model by setting these:
# EVAL_PROVIDER=anthropic
# EVAL_MODEL=claude-sonnet-4-6
# EVAL_API_KEY=
# EVAL_BASE_URL=
EVAL_TENANT_ID=tenant_a
EVAL_AGENT_ID=field_user_agent
EVAL_THRESHOLD=0.7
