# PostgreSQL Configuration (Updated Port)
DB_HOST=localhost
DB_PORT=5435
DB_USER=a2a_user
DB_PASSWORD=secure_password_change_me
DB_NAME=a2a_db
# Read-only role used by the SQL Skill to run generated SELECTs (§7.2)
DB_READONLY_USER=a2a_readonly
DB_READONLY_PASSWORD=readonly_secure_password_change_me

# Redis Cache Configuration (Updated Port)
REDIS_HOST=localhost
REDIS_PORT=6385
REDIS_PASSWORD=redis_secure_password_change_me
REDIS_DB=0

# Ollama / Qwen Configuration
LLM_MODEL=qwen2:7b
LLM_TIMEOUT=120

# Application Configuration
# Number of recent conversation turns loaded per session for context (§3.1)
APP_MEMORY_TURNS=5

# ClickHouse Configuration
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8125
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=secure_password_change_me