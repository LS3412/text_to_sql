# PostgreSQL Configuration (Updated Port)
DB_HOST=localhost
DB_PORT=5435
DB_USER=a2a_user
DB_PASSWORD=secure_password_change_me
DB_NAME=a2a_db
# Read-only role used by the SQL Skill to run generated SELECTs (§7.2)
DB_READONLY_USER=a2a_readonly
DB_READONLY_PASSWORD=readonly_secure_password_change_me

# Redis Cache Configuration (Updated Port)
REDIS_HOST=localhost
REDIS_PORT=6385
REDIS_PASSWORD=redis_secure_password_change_me
REDIS_DB=0

# Ollama / Qwen Configuration
LLM_MODEL=qwen2:7b
LLM_TIMEOUT=120

# Application Configuration
# Number of recent conversation turns loaded per session for context (§3.1)
APP_MEMORY_TURNS=5

# ClickHouse Configuration
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8125
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=secure_password_change_me

# --- 11-stage pipeline configuration (all optional; safe defaults reproduce prior behavior) ---

# Stage 1 — Query Classifier & Database Router
ROUTER_USE_LLM_FALLBACK=false          # optional tiny LLM tie-breaker for ambiguous questions
ROUTER_DEFAULT_PROFILE=postgres        # postgres | alloydb | clickhouse (dialect target)

# Stage 2 — Semantic Layer (data dictionary)
SEMANTIC_DICTIONARY_PATH=config/semantic/dictionary.yaml

# Stage 3 — RAG embeddings + retrieval (hybrid: ClickHouse keyword + pgvector rerank)
EMBED_MODEL=nomic-embed-text           # ollama pull nomic-embed-text
EMBED_BASE_URL=http://localhost:11434
EMBED_DIM=768
RETRIEVAL_TOP_K_TABLES=5
RETRIEVAL_VECTOR_ENABLED=true          # set false to force keyword-only retrieval

# Stage 8/10 — transpiler + auto-correction loop
PIPELINE_TARGET_DIALECT=postgres       # postgres | alloydb | clickhouse
PIPELINE_MAX_CORRECTION_RETRIES=2      # 2 -> at most 3 generation attempts
PIPELINE_ENABLE_CORRECTION_LOOP=true
PIPELINE_CORRECTION_BUDGET_SECONDS=0   # 0 = no wall-clock budget on the loop
# Schema-embedding index DSN (pgvector-enabled Postgres). Empty -> use the app DB url.
# In the portable no-admin stack this points at the pgvector instance (e.g. port 5433).
PIPELINE_PGVECTOR_DSN=